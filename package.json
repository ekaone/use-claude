{
  "name": "@ekaone/use-claude",
  "version": "0.0.2",
  "description": "React hook for talking to Claude Code CLI via Tauri IPC — for Tauri desktop apps only",
  "author": "ekaone",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ekaone/use-claude"
  },
  "keywords": [
    "claude",
    "claude-code",
    "tauri",
    "tauri-plugin",
    "desktop",
    "react",
    "hook",
    "ai",
    "agent"
  ],

  "type": "module",

  "exports": {
    ".": {
      "import": "./dist/core/index.js",
      "types": "./dist/core/index.d.ts"
    },
    "./react": {
      "import": "./dist/react/useClaudeCode.js",
      "types": "./dist/react/useClaudeCode.d.ts"
    },
    "./svelte": {
      "import": "./dist/svelte/useClaudeCode.js",
      "types": "./dist/svelte/useClaudeCode.d.ts"
    },
    "./vue": {
      "import": "./dist/vue/useClaudeCode.js",
      "types": "./dist/vue/useClaudeCode.d.ts"
    }
  },

  "main": "./dist/core/index.js",
  "types": "./dist/core/index.d.ts",

  "files": [
    "dist",
    "README.md"
  ],

  "scripts": {
    "build": "tsup",
    "build:watch": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "lint": "eslint src --ext .ts,.tsx",
    "clean": "rimraf dist",
    "prepublishOnly": "pnpm run clean && pnpm run typecheck && pnpm run test && pnpm run build"
  },

  "devDependencies": {
    "@tauri-apps/api": "^2.10.1",
    "@types/react": "^19.2.14",
    "react": "^19.2.4",
    "rimraf": "^6.1.3",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  },

  "peerDependencies": {
    "@tauri-apps/api": "^2",
    "react": ">=18",
    "svelte": ">=4",
    "vue": ">=3"
  },
  "peerDependenciesMeta": {
    "react": { "optional": true },
    "svelte": { "optional": true },
    "vue": { "optional": true }
  },

  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false
}